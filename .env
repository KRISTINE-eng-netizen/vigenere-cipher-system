# ── Server ──────────────────────────────────────────────
# WebHostMost's Node.js selector sets PORT for you automatically.
# For local dev (XAMPP), leave as-is or change if 3000 is taken.
PORT=3000

# WebHostMost REQUIRES 127.0.0.1 (not 0.0.0.0) — do not change this on that host.
HOST=127.0.0.1

# ── Database ────────────────────────────────────────────
# Fill these in with your MySQL credentials.
# - Local (XAMPP): usually DB_HOST=localhost, DB_USER=root, DB_PASSWORD= (blank)
# - WebHostMost: get these from the MySQL Databases section in your panel
# - TiDB Cloud / other managed MySQL: get these from your cluster's connect page
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=vigenere_db
DB_PORT=3306

# Set to true only if your DB provider requires SSL (e.g. TiDB Cloud).
# Leave false for XAMPP / most shared hosting MySQL.
DB_SSL=false
